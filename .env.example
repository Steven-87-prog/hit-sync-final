PORT=4000
JWT_SECRET=change_this_to_a_long_random_string
# Leave blank for local dev (defaults to ./data). In production without a
# persistent disk, leave this blank too — Upstash Redis (below) is used
# instead. See DEPLOY.md for details.
DATA_DIR=
# Optional even in production, but required if you want data to survive
# restarts on a host without a persistent disk (e.g. Render's free tier).
# Free forever at https://upstash.com — create a Redis database, copy these
# two values from its REST API section. Leave blank for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
